# =============================================================
# Nginx Server Block: phpMyAdmin — port {{ pma_port }}
# Generated by Ansible | Do not edit manually
# Restricted to specific IPs via AWS Security Group (port 8080)
# =============================================================

server {
    listen {{ pma_port }};
    server_name {{ domain }} _;

    root  /usr/share/phpmyadmin;
    index index.php index.html;

    # ── Logging ──────────────────────────────────────────────
    access_log /var/log/nginx/phpmyadmin_access.log;
    error_log  /var/log/nginx/phpmyadmin_error.log;

    # ── HTTP Basic Auth (first layer of protection) ──────────
    auth_basic           "phpMyAdmin — Restricted Access";
    auth_basic_user_file /etc/nginx/.htpasswd;

    # ── PHP handling ─────────────────────────────────────────
    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        try_files            $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass         unix:{{ php_fpm_socket }};
        fastcgi_index        index.php;
        fastcgi_param        SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include              fastcgi_params;
        fastcgi_read_timeout 60;
    }

    # ── Block sensitive phpMyAdmin paths ─────────────────────
    location ~* ^/(libraries|templates|setup/lib) {
        deny all;
        return 403;
    }

    location ~ /\.(ht|git) {
        deny all;
        return 403;
    }
}
