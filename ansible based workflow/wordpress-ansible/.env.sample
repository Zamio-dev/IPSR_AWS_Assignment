# =============================================================
# WordPress Ansible Deployment — Secrets (Sample)
# =============================================================
# Copy this file to .env and replace each value with your own.
# DO NOT commit .env to version control.

# ── Website User ──────────────────────────────────────────────
WP_USER_PASSWORD=CHANGE_ME

# ── MariaDB 10.6 ──────────────────────────────────────────────
DB_ROOT_PASSWORD=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# ── WordPress ─────────────────────────────────────────────────
WP_ADMIN_PASSWORD=CHANGE_ME

# ── phpMyAdmin ────────────────────────────────────────────────
PMA_HTPASSWD_PASSWORD=CHANGE_ME
